@Library('my-shared-library') _

pipeline {
    agent any
    stages {
        stage('Notify Start') {
            steps {
                script {
                    // This calls the logic in src/com/helper/Notification.groovy
                    new com.helper.Notification(this).send("Started")
                }
            }
        }
        stage('Deploy Microservice') {
            steps {
                echo "--- PHASE: VALIDATION ---"
                // Your microservice logic here
                echo "Executing deployment tasks..."
            }
        }
    }
    post {
        success { 
            script { new com.helper.Notification(this).send("Success") } 
        }
        failure { 
            script { new com.helper.Notification(this).send("Failure") } 
        }
    }
}
