@Library('my-shared-library') _
import com.helper.Notification
import com.helper.Deployer

pipeline {
    agent any
    
    stages {
        stage('Deploy Microservice') {
            steps {
                script {
                    def deployer = new com.helper.Deployer(this)
                    deployer.validate(params.ENVIRONMENT)
                    // Add your actual deployment commands here
                }
            }
        }
    }

    post {
        always {
            script {
                def notify = new com.helper.Notification(this)

                if (currentBuild.result == 'SUCCESS') {
                    notify.send("Success")
                } else if (currentBuild.result == 'FAILURE') {
                    notify.send("Failure")
                } else if (currentBuild.result == 'UNSTABLE') {
                    notify.send("Unstable")
                }
            }
        }
    }
}
