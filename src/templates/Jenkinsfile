@Library('my-shared-library') _

pipeline {
    agent any

    // This block creates the ENVIRONMENT tab/dropdown
    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev', 'test', 'prod'], description: 'Select the environment to deploy to.')
    }

    stages {
        stage('Notify Start') {
            steps {
                script {
                    // This uses your constant logic from Notification.groovy
                    new com.helper.Notification(this).send("Started")
                }
            }
        }

        stage('Dev Environment') {
            steps {
                echo "Simulating a build failure..."
                // This triggers the 'failure' block in post
                sh "exit 1" 
            }
        }

        stage('Deploy Phase') {
            steps {
                // This prints the environment picked in the dropdown
                echo "Deploying to ${params.ENVIRONMENT} environment..."
            }
        }
    }

    post {
        success { 
            script { new com.helper.Notification(this).send("Success") } 
        }
        failure { 
            script { new com.helper.Notification(this).send("Failure") } 
        }
        unstable { 
            script { new com.helper.Notification(this).send("Unstable") } 
        }
    }
}
