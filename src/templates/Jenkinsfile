@Library('my-shared-library') _

pipeline {
    agent any

    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev', 'test', 'prod'], description: 'Select the environment to deploy to.')
    }

    stages {
        stage('Notify Start') {
            steps {
                script { new com.helper.Notification(this).send("Started") }
            }
        }

        stage('Testing') {
            parallel {
                stage('Unit Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn test -Dtest=Unit*'
                        }
                    }
                }
                stage('Integration Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn test -Dtest=Integration*'
                        }
                    }
                }
            }
        }

        stage('Generate Reports & Artifacts') {
            steps {
                sh 'mvn site pdf:pdf'
                archiveArtifacts artifacts: 'target/pdf/*.pdf, target/site/jacoco/**', fingerprint: true
            }
        }

        stage('Deployment') {
            steps {
                echo "Deploying to ${params.ENVIRONMENT}..."
                sh "sleep 15"
            }
        }
    }

    post {
        always {
            // Publishes JUnit test results to the Jenkins UI
            junit '**/target/surefire-reports/*.xml'
            // Cleans the workspace to keep the agent storage healthy
            cleanWs()
        }
        success { 
            script { new com.helper.Notification(this).send("Success") } 
        }
        failure { 
            script { new com.helper.Notification(this).send("Failure") } 
        }
        unstable { 
            script { new com.helper.Notification(this).send("Unstable") } 
        }
    }
}
