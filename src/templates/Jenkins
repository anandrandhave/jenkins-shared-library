pipeline {
    agent any

    tools {
        maven 'Maven3'
        jdk 'JDK'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean install -DskipTests'
            }
        }

        stage('Parallel Tests') {
            parallel {

                stage('Unit Tests') {
                    steps {
                        sh 'mvn -Dtest=UnitTest test'
                    }
                }

                stage('Integration Tests') {
                    steps {
                        sh 'mvn -Dtest=IntegrationTest test'
                    }
                }

                stage('E2E Tests') {
                    steps {
                        sh 'mvn -Dtest=E2ETest test'
                    }
                }
            }
        }

        stage('Generate Site Report') {
            steps {
                sh 'mvn site'
            }
        }

        stage('Generate PDF') {
            steps {
                sh '''
                wkhtmltopdf target/site/index.html target/site/report.pdf
                '''
            }
        }

        stage('Archive Artifacts') {
            steps {
                archiveArtifacts artifacts: 'target/site/report.pdf', fingerprint: true
                junit '**/target/surefire-reports/*.xml'
            }
        }
    }

    post {
        always {
            script {
                def msg = """Job: ${env.JOB_NAME}

Branch: ${env.BRANCH_NAME ?: 'N/A'}

Environment: dev

Stages:
✔ Build
✔ Unit Tests
✔ Integration Tests
✔ E2E Tests

Build URL: ${env.BUILD_URL}

Console: ${env.BUILD_URL}console

PDF Report: ${env.BUILD_URL}artifact/target/site/report.pdf
"""

                slackSend(
                    channel: '#all-admin',
                    message: msg,
                    color: currentBuild.currentResult == 'SUCCESS' ? 'good' : 'danger'
                )
            }
        }
    }
}
