pipeline {
    agent any

    tools {
        maven 'Maven3'
        jdk 'JDK'
    }

    environment {
        ENVIRONMENT = 'dev'
        FAILED_STAGE = ''
    }

    stages {

        stage('Checkout') {
            steps {
                script { env.FAILED_STAGE = 'Checkout' }
                checkout scm
            }
        }

        stage('Build') {
            steps {
                script { env.FAILED_STAGE = 'Build' }
                sh 'mvn clean compile'
            }
        }

        stage('Parallel Tests') {
            parallel {

                stage('Unit Tests') {
                    steps {
                        script { env.FAILED_STAGE = 'Unit Tests' }
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=UnitTest test'
                        }
                    }
                }

                stage('Integration Tests') {
                    steps {
                        script { env.FAILED_STAGE = 'Integration Tests' }
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=IntegrationTest test'
                        }
                    }
                }

                stage('E2E Tests') {
                    steps {
                        script { env.FAILED_STAGE = 'E2E Tests' }
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=E2ETest test'
                        }
                    }
                }
            }
        }

        // ✅ Publish Test Results
        stage('Publish Test Results') {
            steps {
                junit '**/target/surefire-reports/*.xml'
            }
        }

        // ✅ Publish JaCoCo Coverage
        stage('Coverage Report') {
            steps {
                publishHTML([
                    reportDir: 'target/site/jacoco',
                    reportFiles: 'index.html',
                    reportName: 'JaCoCo Report'
                ])
            }
        }
    }

    post {

        success {
            script {
                slackSend(
                    channel: '#all-admin',
                    message: """
✅ *Build #${env.BUILD_NUMBER} SUCCESS*

📦 Job: ${env.JOB_NAME}
🌿 Branch: ${env.BRANCH_NAME ?: 'N/A'}
🌍 Environment: ${env.ENVIRONMENT}

🧪 Tests: Completed Successfully

🔗 Build: ${env.BUILD_URL}
📄 Logs: ${env.BUILD_URL}console
📊 Coverage: ${env.BUILD_URL}HTML_20Report/
"""
                )
            }
        }

        unstable {
            script {
                slackSend(
                    channel: '#all-admin',
                    message: """
⚠ *Build #${env.BUILD_NUMBER} UNSTABLE*

📦 Job: ${env.JOB_NAME}
🌿 Branch: ${env.BRANCH_NAME ?: 'N/A'}
🌍 Environment: ${env.ENVIRONMENT}

❗ Some tests failed

🔗 Build: ${env.BUILD_URL}
📄 Logs: ${env.BUILD_URL}console
📊 Coverage: ${env.BUILD_URL}HTML_20Report/
"""
                )
            }
        }

        failure {
            script {
                slackSend(
                    channel: '#all-admin',
                    message: """
❌ *Build #${env.BUILD_NUMBER} FAILED*

📦 Job: ${env.JOB_NAME}
🌿 Branch: ${env.BRANCH_NAME ?: 'N/A'}
🌍 Environment: ${env.ENVIRONMENT}

🔥 Failed Stage: ${env.FAILED_STAGE}

🔗 Build: ${env.BUILD_URL}
📄 Logs: ${env.BUILD_URL}console
"""
                )
            }
        }

        always {
            echo "Pipeline completed"
        }
    }
}
