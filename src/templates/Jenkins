@Library('my-shared-library') _

pipeline {
    agent any

    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev', 'staging', 'prod'], description: 'Select Environment')
    }

    stages {
        stage('Checkout SCM') {
            steps {
                checkout scm
            }
        }

        stage('Setup') {
            steps {
                sh 'mvn dependency:resolve'
            }
        }

        stage('Unit Tests') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh 'mvn test -Dtest=UnitTest' 
                }
            }
        }

        stage('Coverage Check') {
            steps {
                // Triggers the 60% check and creates data for the PDF
                sh 'mvn jacoco:prepare-agent test jacoco:report jacoco:check'
            }
        }

        stage('Parallel: Integration + Lint') {
            parallel {
                stage('Integration Tests') {
                    steps {
                        sh 'mvn test -Dtest=IntegrationTest'
                    }
                }
                stage('Lint & Static Analysis') {
                    steps {
                        // Generates the logs seen in your artifacts list
                        sh 'mvn compile > pylint.log' 
                    }
                }
            }
        }

        stage('E2E Tests') {
            steps {
                sh 'mvn test -Dtest=E2ETest'
            }
        }

        stage('Generate PDF Report') {
            steps {
                script {
                    // Uses the Python script to build the visual report
                    sh "python3 generate_report.py --jobName '${JOB_NAME}' --buildNum '${BUILD_NUMBER}' --branch '${env.BRANCH_NAME ?: 'main'}' --env '${params.ENVIRONMENT}'"
                }
            }
        }

        stage('Publish Reports') {
            steps {
                // Archives all files shown in your reference
                archiveArtifacts artifacts: '*.pdf, *.log, target/*.xml', fingerprint: true
                publishHTML([allowMissing: false, alwaysLinkToLastBuild: true, keepAll: true, 
                            reportDir: 'target/site/jacoco', reportFiles: 'index.html', reportName: 'JaCoCo Report'])
            }
        }
    }

    post {
        success {
            script {
                // Generates clickable links for Slack notifications
                def coverageUrl = "${env.BUILD_URL}JaCoCo_Report/"
                def pdfUrl = "${env.BUILD_URL}artifact/test-report.pdf"
                new com.helper.Notification(this).send("Success", coverageUrl, pdfUrl)
            }
        }
    }
}
