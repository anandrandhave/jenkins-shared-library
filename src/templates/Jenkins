pipeline {
    agent any

    tools {
        maven 'Maven3'
        jdk 'JDK'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean compile'
            }
        }

        // ✅ Parallel Execution
        stage('Parallel Tests') {
            parallel {

                stage('Unit Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=UnitTest test'
                        }
                    }
                }

                stage('Integration Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=IntegrationTest test'
                        }
                    }
                }

                stage('E2E Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=E2ETest test'
                        }
                    }
                }
            }
        }

        // ✅ ADD THIS STAGE (PDF + Coverage)
        stage('Generate Reports') {
            steps {
                sh 'mvn site pdf:pdf'
            }
        }

        // ✅ ADD THIS (Artifacts)
        stage('Archive Artifacts') {
            steps {
                archiveArtifacts artifacts: 'target/pdf/*.pdf, target/site/jacoco/**', fingerprint: true
            }
        }
    }

    // ✅ ADD THIS (Test Results + Slack)
    post {

        always {
            junit '**/target/surefire-reports/*.xml'
        }

        success {
            slackSend(
                channel: '#all-admin',
                teamDomain: 'admin-ngv1996',              // ✅ MUST MATCH
                tokenCredentialId: 'my-slack-token-id',  // ✅ MUST MATCH
                message: """
✅ Build SUCCESS

Job: ${env.JOB_NAME}
Build: ${env.BUILD_NUMBER}

🔗 ${env.BUILD_URL}
"""
            )
        }

        failure {
            slackSend(
                channel: '#all-admin',
                teamDomain: 'admin-ngv1996',
                tokenCredentialId: 'my-slack-token-id',
                message: """
❌ Build FAILED

Job: ${env.JOB_NAME}
Build: ${env.BUILD_NUMBER}

🔗 ${env.BUILD_URL}
"""
            )
        }
    }
}
