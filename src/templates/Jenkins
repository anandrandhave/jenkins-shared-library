pipeline {
    agent any

    tools {
        maven 'Maven3'
        jdk 'JDK'
    }

    environment {
        JOB_NAME = "OT-Microservices-Employee-Service"
        ENV = "dev"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean compile'
            }
        }

        // ✅ Parallel Testing
        stage('Parallel Tests') {
            parallel {

                stage('Unit Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=*UnitTest test'
                        }
                    }
                }

                stage('Integration Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=*IntegrationTest test'
                        }
                    }
                }

                stage('E2E Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=*E2ETest test'
                        }
                    }
                }
            }
        }

        // ✅ Generate Site (HTML report)
        stage('Generate Site Report') {
            steps {
                sh 'mvn clean verify site'
            }
        }

        stage('Debug Site') {
            steps {
                sh 'ls -l target/site/'
            }
        }

        // ✅ FIXED PDF GENERATION
        stage('Generate PDF') {
            steps {
                sh '''
                wkhtmltopdf \
                --enable-local-file-access \
                target/site/index.html target/site/report.pdf
                '''
            }
        }

        // ✅ Archive PDF
        stage('Archive Artifacts') {
            steps {
                archiveArtifacts artifacts: 'target/site/report.pdf', fingerprint: true
            }
        }
    }

    // ✅ POST SECTION (END)
    post {

        always {
            junit '**/target/surefire-reports/*.xml'
        }

        success {
            script {
                slackSend(
                    channel: '#all-admin',
                    color: 'good',
                    message: """
✅ Build SUCCESS

Job: ${env.JOB_NAME}
Branch: ${env.BRANCH_NAME ?: 'N/A'}
Environment: ${env.ENV}

Stages:
✔ Build
✔ Unit Tests
✔ Integration Tests
✔ E2E Tests

Build URL: ${env.BUILD_URL}
Console: ${env.BUILD_URL}console
"""
                )
            }
        }

        failure {
            script {
                slackSend(
                    channel: '#all-admin',
                    color: 'danger',
                    message: """
❌ Build FAILED

Job: ${env.JOB_NAME}
Branch: ${env.BRANCH_NAME ?: 'N/A'}
Environment: ${env.ENV}

Check logs:
${env.BUILD_URL}console
"""
                )
            }
        }
    }
}
