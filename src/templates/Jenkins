@Library('my-shared-library') _

pipeline {
    agent any

    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev', 'test', 'prod'], description: 'Select environment.')
    }

    stages {
        stage('Notify Start') {
            steps {
                script {
                    // This sends the "Started" message you see in your Slack screenshot
                    new com.helper.Notification(this).send("Started")
                }
            }
        }

        stage('Testing') {
            parallel {
                stage('Unit Tests') {
                    steps {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            // Run tests and generate report. 
                            // The 80% check now happens automatically via pom.xml.
                            sh 'mvn clean test jacoco:report -Djacoco.skip=false'
                        }
                    }
                }
                stage('Integration Tests') {
                    steps {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            // Added flag to prevent failure if no "Integration*" tests are found
                            sh 'mvn test -Dtest=Integration* -Dsurefire.failIfNoSpecifiedTests=false'
                        }
                    }
                }
            }
        }

        stage('Generate Custom PDF Report') {
            steps {
                script {
                    // Generates the PDF summary shown in your logs
                    sh "python3 generate_report.py --jobName '${JOB_NAME}' --buildNum '${BUILD_NUMBER}' --branch '${env.BRANCH_NAME ?: 'main'}' --env '${params.ENVIRONMENT}' --test_results 'target/surefire-reports'"
                }
            }
        }
        
        stage('Archive') {
            steps {
                // Important: This makes the PDF available for the Slack "Download" link
                archiveArtifacts artifacts: 'target/pdf/*.pdf, *.pdf', fingerprint: true
            }
        }
    }

    post {
        always {
            junit testResults: '**/target/surefire-reports/*.xml', allowEmptyResults: true
            
            // Added allowMissing: true so the pipeline doesn't crash if JaCoCo skips a step
            publishHTML([allowMissing: true, alwaysLinkToLastBuild: true, keepAll: true, 
                reportDir: 'target/site/jacoco', reportFiles: 'index.html', reportName: 'JaCoCo Report'])
        }
        success {
            script { 
                // These generate the clickable URLs for your Slack message
                def coverageUrl = "${env.BUILD_URL}JaCoCo_Report/"
                def pdfUrl = "${env.BUILD_URL}artifact/test-report.pdf"
                
                new com.helper.Notification(this).send("Success", coverageUrl, pdfUrl) 
            }
        }
        failure {
            script { 
                new com.helper.Notification(this).send("Failure") 
            }
        }
        cleanup {
            cleanWs()
        }
    }
}
