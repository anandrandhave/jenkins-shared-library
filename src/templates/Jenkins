pipeline {
    agent any

    tools {
        maven 'Maven3'
        jdk 'JDK'
    }

    environment {
        JOB_NAME = "OT-Microservices-Employee-Service"
        ENV = "dev"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean compile'
            }
        }

        // ✅ Parallel Testing
        stage('Parallel Tests') {
            parallel {

                stage('Unit Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=*UnitTest test'
                        }
                    }
                }

                stage('Integration Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=*IntegrationTest test'
                        }
                    }
                }

                stage('E2E Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=*E2ETest test'
                        }
                    }
                }
            }
        }

        // ✅ Aggregate reports
        stage('Aggregate Reports') {
            steps {
                sh 'mvn verify'
            }
        }

        // ✅ Generate HTML reports
        stage('Generate Site') {
            steps {
                sh 'mvn site'
            }
        }

        // ✅ Debug (optional but useful)
        stage('Debug Site Files') {
            steps {
                sh '''
                echo "===== SITE FILES ====="
                ls -l target/site/
                '''
            }
        }

        // ✅ Generate + Archive PDF (FINAL FIXED)
        stage('Generate & Archive PDF') {
            steps {
                sh '''
                echo "===== GENERATING PDF ====="

                wkhtmltopdf \
                --enable-local-file-access \
                --load-error-handling ignore \
                --load-media-error-handling ignore \
                target/site/summary.html \
                target/site/surefire-report.html \
                target/site/jacoco/index.html \
                target/site/report.pdf

                echo "===== VERIFY PDF ====="
                ls -l target/site/
                '''

                script {
                    if (fileExists('target/site/report.pdf')) {
                        echo "✅ PDF FOUND - Archiving..."
                        archiveArtifacts artifacts: 'target/site/report.pdf', fingerprint: true
                    } else {
                        echo "❌ PDF NOT GENERATED"
                    }
                }
            }
        }
    }

    // ✅ POST (REPORT + SLACK)
    post {

        always {
            junit '**/target/surefire-reports/*.xml'
        }

        success {
            script {
                slackSend(
                    channel: '#all-admin',
                    color: 'good',
                    message: """
✅ *Build SUCCESS*

*Job:* ${env.JOB_NAME}  
*Environment:* ${env.ENV}  

*Stages:*  
✔ Build  
✔ Unit Tests  
✔ Integration Tests  
✔ E2E Tests  
✔ Reports Generated  
✔ PDF Generated  

*Build URL:* ${env.BUILD_URL}  
*Console:* ${env.BUILD_URL}console  
"""
                )
            }
        }

        failure {
            script {
                slackSend(
                    channel: '#all-admin',
                    color: 'danger',
                    message: """
❌ *Build FAILED*

*Job:* ${env.JOB_NAME}  
*Environment:* ${env.ENV}  

⚠ One or more stages failed  

*Build URL:* ${env.BUILD_URL}  
*Console:* ${env.BUILD_URL}console  
"""
                )
            }
        }
    }
}
