pipeline {
    agent any

    tools {
        maven 'Maven3'
        jdk 'JDK'
    }

    environment {
        JOB_NAME = "OT-Microservices-Employee-Service"
        ENV = "dev"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean compile'
            }
        }

        // ✅ Parallel Testing
        stage('Parallel Tests') {
            parallel {

                stage('Unit Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=*UnitTest test'
                        }
                    }
                }

                stage('Integration Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=*IntegrationTest test'
                        }
                    }
                }

                stage('E2E Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=*E2ETest test'
                        }
                    }
                }
            }
        }

        // 🔥 VERY IMPORTANT (generates reports data)
        stage('Aggregate Reports') {
            steps {
                sh 'mvn verify'
            }
        }

        // ✅ Generate Maven Site (HTML reports)
        stage('Generate Site') {
            steps {
                sh 'mvn clean verify site'
            }
        }

        // ✅ Debug files (helps if PDF empty)
        stage('Debug Site Files') {
            steps {
                sh '''
                echo "===== SITE FILES ====="
                ls -l target/site/
                '''
            }
        }

        // ✅ Generate PDF from REAL reports
        stage('Generate PDF') {
            steps {
                sh '''
                echo "===== GENERATING PDF ====="

                wkhtmltopdf \
                --enable-local-file-access \
                --load-error-handling ignore \
                --load-media-error-handling ignore \
                target/site/summary.html \
                target/site/surefire-report.html \
                target/site/jacoco/index.html \
                target/site/report.pdf

                echo "===== PDF GENERATED ====="
                ls -l target/site/report.pdf
                '''
            }
        }

        // ✅ Archive PDF
        stage('Archive Artifacts') {
            steps {
                archiveArtifacts artifacts: 'target/site/report.pdf', fingerprint: true
            }
        }
    }

    post {
        always {
            junit '**/target/surefire-reports/*.xml'
        }

        success {
            script {
                slackSend(
                    channel: '#all-admin',
                    color: 'good',
                    message: """
✅ Job: ${env.JOB_NAME}
Environment: ${env.ENV}

✔ Build SUCCESS
✔ Tests PASSED
✔ PDF Generated

Build URL: ${env.BUILD_URL}
Console: ${env.BUILD_URL}console
"""
                )
            }
        }

        failure {
            script {
                slackSend(
                    channel: '#all-admin',
                    color: 'danger',
                    message: """
❌ Job: ${env.JOB_NAME}
Environment: ${env.ENV}

⚠ Build FAILED

Build URL: ${env.BUILD_URL}
Console: ${env.BUILD_URL}console
"""
                )
            }
        }
    }
}
