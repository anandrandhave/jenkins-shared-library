pipeline {
    agent any

    tools {
        maven 'Maven3'
        jdk 'JDK'
    }

    environment {
        JOB_NAME = "OT-Microservices-Employee-Service"
        ENV = "dev"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean compile'
            }
        }

        // ✅ Parallel Testing
        stage('Parallel Tests') {
            parallel {

                stage('Unit Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=*UnitTest test'
                        }
                    }
                }

                stage('Integration Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=*IntegrationTest test'
                        }
                    }
                }

                stage('E2E Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=*E2ETest test'
                        }
                    }
                }
            }
        }

        // ✅ Generate Maven Site (HTML Reports)
        stage('Generate Site') {
            steps {
                sh 'mvn clean verify site'
            }
        }

        // ✅ DEBUG 1: Check site folder
        stage('Debug Site Files') {
            steps {
                sh '''
                echo "===== LIST SITE FILES ====="
                ls -l target/site/ || true
                '''
            }
        }

        // ✅ DEBUG 2: Check important files
        stage('Debug Key Files') {
            steps {
                sh '''
                echo "===== CHECK IMPORTANT FILES ====="
                ls target/site/index.html || true
                ls target/site/surefire-report.html || true
                ls target/site/jacoco/index.html || true
                '''
            }
        }

        // ✅ DEBUG 3: Check wkhtmltopdf
        stage('Check wkhtmltopdf') {
            steps {
                sh '''
                echo "===== WKHTMLTOPDF VERSION ====="
                wkhtmltopdf -V || true
                '''
            }
        }

        // ✅ Generate PDF (FINAL FIXED)
        stage('Generate PDF') {
            steps {
                sh '''
                echo "===== GENERATING PDF ====="

                wkhtmltopdf \
                --enable-local-file-access \
                --disable-smart-shrinking \
                --no-stop-slow-scripts \
                --load-error-handling ignore \
                --load-media-error-handling ignore \
                target/site/index.html target/site/report.pdf

                echo "===== PDF GENERATED FILES ====="
                ls -l target/site/report.pdf || true
                '''
            }
        }

        // ✅ Archive PDF
        stage('Archive Artifacts') {
            steps {
                archiveArtifacts artifacts: 'target/site/report.pdf', fingerprint: true
            }
        }
    }

    // ✅ POST SECTION (Slack + Reports)
    post {

        always {
            junit '**/target/surefire-reports/*.xml'
        }

        success {
            script {
                slackSend(
                    channel: '#all-admin',
                    color: 'good',
                    message: """
✅ Build SUCCESS

Job: ${env.JOB_NAME}
Branch: ${env.BRANCH_NAME ?: 'N/A'}
Environment: ${env.ENV}

Stages:
✔ Build
✔ Unit Tests
✔ Integration Tests
✔ E2E Tests
✔ PDF Generated

Build URL: ${env.BUILD_URL}
Console: ${env.BUILD_URL}console
"""
                )
            }
        }

        failure {
            script {
                slackSend(
                    channel: '#all-admin',
                    color: 'danger',
                    message: """
❌ Build FAILED

Job: ${env.JOB_NAME}
Environment: ${env.ENV}

Check logs:
${env.BUILD_URL}console
"""
                )
            }
        }
    }
}
