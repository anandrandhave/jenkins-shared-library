pipeline {
    agent any

    tools {
        maven 'Maven'
        jdk 'JDK21'
    }

    environment {
        SONAR_PROJECT_KEY = 'OT-Microservices-Employee-Service'
        SONAR_HOST_URL   = 'http://192.168.1.7:9000'
        PDF_PATH         = 'target/site/report.pdf'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build & Test') {
            steps {
                sh 'mvn clean verify'
            }
            post {
                always {
                    junit '**/target/surefire-reports/*.xml'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                        script {

                            def cmd = "mvn sonar:sonar " +
                                      "-Dsonar.projectKey=${SONAR_PROJECT_KEY} " +
                                      "-Dsonar.host.url=${SONAR_HOST_URL} " +
                                      "-Dsonar.login=$SONAR_TOKEN "

                            if (env.CHANGE_ID) {
                                cmd += "-Dsonar.pullrequest.key=${env.CHANGE_ID} "
                                cmd += "-Dsonar.pullrequest.branch=${env.CHANGE_BRANCH} "
                                cmd += "-Dsonar.pullrequest.base=${env.CHANGE_TARGET} "
                            } else if (env.BRANCH_NAME && env.BRANCH_NAME != "null") {
                                // ⚠ Only if NOT Community Edition OR safe value exists
                                cmd += "-Dsonar.branch.name=${env.BRANCH_NAME} "
                            }

                            sh cmd
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Generate Site') {
            steps {
                sh 'mvn site'
            }
        }

        stage('Debug Site Files') {
            steps {
                sh '''
                echo "===== SITE FILES ====="
                ls -l target/site/
                '''
            }
        }

        stage('Generate & Archive PDF') {
            steps {
                sh '''
                mkdir -p target/site

                cat > target/site/full-report.html <<EOF
<html><body><h1>CI/CD Report</h1>
EOF

                cat target/site/summary.html >> target/site/full-report.html || true
                cat target/site/surefire-report.html >> target/site/full-report.html || true
                cat target/site/jacoco/index.html >> target/site/full-report.html || true

                echo "</body></html>" >> target/site/full-report.html

                cd target/site

                wkhtmltopdf \
                --enable-local-file-access \
                --page-size A4 \
                --margin-top 10 \
                --margin-bottom 10 \
                --margin-left 10 \
                --margin-right 10 \
                --zoom 0.9 \
                --load-error-handling ignore \
                --load-media-error-handling ignore \
                full-report.html report.pdf
                '''
            }

            post {
                success {
                    archiveArtifacts artifacts: 'target/site/report.pdf', fingerprint: true
                }
            }
        }
    }

    post {
        success {
            script {
                def reportUrl = "${env.BUILD_URL}artifact/${PDF_PATH}"

                echo "📄 PDF LINK: ${reportUrl}"

                slackSend(
                    channel: '#all-admin',
                    color: 'good',
                    message: "✅ SUCCESS: ${env.JOB_NAME} #${env.BUILD_NUMBER}\n📄 ${reportUrl}"
                )

                withCredentials([string(credentialsId: 'slack-bot-token', variable: 'SLACK_TOKEN')]) {
                    sh '''
                    curl -X POST https://slack.com/api/files.upload \
                    -H "Authorization: Bearer $SLACK_TOKEN" \
                    -F file=@target/site/report.pdf \
                    -F channels=#all-admin
                    '''
                }
            }
        }

        failure {
            slackSend(
                channel: '#all-admin',
                color: 'danger',
                message: "❌ FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER}"
            )
        }
    }
}
