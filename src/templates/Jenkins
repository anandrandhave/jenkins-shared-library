pipeline {
    agent any

    tools {
        maven 'Maven3'
        jdk 'JDK'
    }

    environment {
        JOB_NAME = "OT-Microservices-Employee-Service"
        ENV = "dev"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean compile'
            }
        }

        stage('Parallel Tests') {
            parallel {

                stage('Unit Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=*UnitTest test'
                        }
                    }
                }

                stage('Integration Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=*IntegrationTest test'
                        }
                    }
                }

                stage('E2E Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=*E2ETest test'
                        }
                    }
                }
            }
        }

        stage('Aggregate Reports') {
            steps {
                sh 'mvn verify'
            }
        }

        // ✅ SONAR ANALYSIS
        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                        sh '''
                        mvn sonar:sonar \
                          -Dsonar.projectKey=OT-Microservices-Employee-Service \
                          -Dsonar.host.url=http://192.168.1.7:9000 \
                          -Dsonar.login=$SONAR_TOKEN \
                          -Dsonar.branch.name=main
                        '''
                    }
                }
            }
        }

        // ✅ QUALITY GATE
        stage('Quality Gate') {
            steps {
                script {
                    timeout(time: 5, unit: 'MINUTES') {
                        def qg = waitForQualityGate()
                        echo "Quality Gate Status: ${qg.status}"
                        if (qg.status != 'OK') {
                            error "❌ Pipeline failed due to Quality Gate failure"
                        }
                    }
                }
            }
        }

        stage('Generate Site') {
            steps {
                sh 'mvn site'
            }
        }

        stage('Debug Site Files') {
            steps {
                sh '''
                echo "===== SITE FILES ====="
                ls -l target/site/
                '''
            }
        }

        stage('Generate & Archive Branded PDF') {
            steps {
                sh '''
                echo "===== GENERATING BRANDED HTML ====="

                mkdir -p target/site

                cat > target/site/full-report.html <<EOF
<html>
<body>

<h2>Summary</h2>
EOF

                cat target/site/summary.html >> target/site/full-report.html

                cat >> target/site/full-report.html <<EOF

<h2>Test Results</h2>
EOF

                cat target/site/surefire-report.html >> target/site/full-report.html

                cat >> target/site/full-report.html <<EOF

<h2>Code Coverage</h2>
EOF

                cat target/site/jacoco/index.html >> target/site/full-report.html

                cat >> target/site/full-report.html <<EOF

</body>
</html>
EOF

                echo "===== GENERATING PDF ====="

                cd target/site

                wkhtmltopdf full-report.html report.pdf

                ls -l report.pdf
                '''

                script {
                    if (fileExists('target/site/report.pdf')) {
                        echo "✅ PDF GENERATED"
                        archiveArtifacts artifacts: 'target/site/report.pdf', fingerprint: true
                    } else {
                        error "❌ PDF not generated!"
                    }
                }
            }
        }
    }

    post {

        always {
            junit '**/target/surefire-reports/*.xml'
        }

        success {
            script {
                slackSend(
                    channel: '#all-admin',
                    color: 'good',
                    message: """
✅ *Build SUCCESS*

*Job:* ${env.JOB_NAME}
*Environment:* ${env.ENV}

✔ Build
✔ Tests
✔ Reports
✔ PDF

*Build URL:* ${env.BUILD_URL}
"""
                )
            }
        }

        failure {
            script {
                slackSend(
                    channel: '#all-admin',
                    color: 'danger',
                    message: """
❌ *Build FAILED*

*Job:* ${env.JOB_NAME}

*Build URL:* ${env.BUILD_URL}
"""
                )
            }
        }
    }
}
