pipeline {
    agent any

    tools {
        maven 'Maven'
        jdk 'JDK'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean compile'
            }
        }

        // ✅ Parallel Execution
        stage('Parallel Tests') {
            parallel {

                stage('Unit Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=UnitTest test'
                        }
                    }
                }

                stage('Integration Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=IntegrationTest test'
                        }
                    }
                }

                stage('E2E Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=E2ETest test'
                        }
                    }
                }
            }
        }

        // ✅ Publish JUnit Reports
        stage('Publish Results') {
            steps {
                junit '**/target/surefire-reports/*.xml'
            }
        }

        // ✅ Code Coverage (JaCoCo)
        stage('Coverage') {
            steps {
                sh 'mvn jacoco:report'

                jacoco(
                    execPattern: '**/target/*.exec',
                    classPattern: '**/target/classes',
                    sourcePattern: '**/src/main/java'
                )
            }
        }

        // ✅ Enforce Coverage Threshold
        stage('Coverage Check') {
            steps {
                script {
                    def coverage = 80   // You can adjust if needed
                    echo "Checking coverage threshold: ${coverage}%"
                    // NOTE: Real enforcement usually needs plugin config or parsing report
                }
            }
        }

        // ✅ Generate PDF Report
        stage('Generate PDF') {
            steps {
                sh 'mkdir -p target'
                sh 'python3 generate_report.py'
            }
        }

        // ✅ Archive PDF Artifact
        stage('Archive') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                    archiveArtifacts artifacts: 'target/*.pdf', fingerprint: true
                }
            }
        }
    }

    // ✅ Always run cleanup/logging
    post {
        always {
            echo "Pipeline completed"
        }
        success {
            echo "Build SUCCESS"
        }
        failure {
            echo "Build FAILED"
        }
    }
}
