pipeline {
    agent any

    tools {
        maven 'Maven'
        jdk 'JDK21'
    }

    environment {
        SONAR_PROJECT_KEY = 'OT-Microservices-Employee-Service'
        SONAR_HOST_URL   = 'http://192.168.1.7:9000'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build & Unit Tests') {
            steps {
                sh 'mvn clean test'
            }
            post {
                always {
                    junit 'target/surefire-reports/*.xml'
                }
            }
        }

        stage('Integration Tests') {
            steps {
                sh 'mvn verify -DskipUnitTests=true'
            }
        }

        stage('E2E Tests') {
            steps {
                echo "Running E2E Tests..."
                sh 'echo "E2E Passed"'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {

                        sh '''
                        mvn sonar:sonar \
                        -Dsonar.projectKey=$SONAR_PROJECT_KEY \
                        -Dsonar.host.url=$SONAR_HOST_URL \
                        -Dsonar.login=$SONAR_TOKEN
                        '''
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Generate Site') {
            steps {
                sh 'mvn site'
            }
        }

        stage('Generate & Archive PDF') {
            steps {
                sh '''
                mkdir -p target/site

                cat > target/site/full-report.html <<EOF
                <html><body><h1>Build Report</h1>
                EOF

                cat target/site/summary.html >> target/site/full-report.html || true
                cat target/site/surefire-report.html >> target/site/full-report.html || true
                cat target/site/jacoco/index.html >> target/site/full-report.html || true

                echo "</body></html>" >> target/site/full-report.html

                cd target/site

                wkhtmltopdf \
                --enable-local-file-access \
                full-report.html report.pdf || true
                '''
            }

            post {
                always {
                    archiveArtifacts artifacts: 'target/site/report.pdf', allowEmptyArchive: true
                }
            }
        }
    }

    post {
        always {
            script {

                def buildStatus = currentBuild.currentResult

                def unit  = "✅"
                def integ = "✅"
                def e2e   = "✅"

                if (buildStatus != "SUCCESS") {
                    unit  = "❌"
                    integ = "❌"
                    e2e   = "❌"
                }

                def pdfLink = "${env.BUILD_URL}artifact/target/site/report.pdf"

                echo "📄 PDF LINK: ${pdfLink}"

                slackSend(
                    channel: '#all-admin',
                    color: (buildStatus == 'SUCCESS') ? 'good' : 'danger',
                    message: """
*🚀 Pipeline Report*

*Job:* ${env.JOB_NAME}
*Build:* #${env.BUILD_NUMBER}
*Status:* ${buildStatus}

*Pipeline Summary:*
${unit} Unit Tests
${integ} Integration Tests
${e2e} E2E Tests
:heavy_check_mark: Reports Generated

📄 *PDF Report:* ${pdfLink}
"""
                )
            }
        }
    }
}
