pipeline {
    agent any
    tools {
        maven 'Maven3'
        jdk 'JDK'
    }
    stages {
        stage('Build & Test') {
            steps {
                sh 'mvn clean compile'
                parallel(
                    "Unit Tests": {
                        catchError(stageResult: 'FAILURE') { sh 'mvn -Dtest=UnitTest test' }
                    },
                    "Integration Tests": {
                        catchError(stageResult: 'FAILURE') { sh 'mvn -Dtest=IntegrationTest test' }
                    },
                    "E2E Tests": {
                        catchError(stageResult: 'FAILURE') { sh 'mvn -Dtest=E2ETest test' }
                    }
                )
            }
        }

        stage('Reporting & Quality Gate') {
            steps {
                junit '**/target/surefire-reports/*.xml'
                jacoco(
                    execPattern: '**/target/jacoco.exec',
                    changeBuildStatus: true,
                    minimumInstructionCoverage: '80'
                )
                // ADDED THE LOCAL FILE ACCESS FLAG HERE:
                sh 'wkhtmltopdf --enable-local-file-access target/site/jacoco/index.html Coverage_Report.pdf || true'
            }
        }
    }
    post {
        always {
            archiveArtifacts artifacts: 'Coverage_Report.pdf, target/site/jacoco/**', allowEmptyArchive: true
        }
        success {
            slackSend(channel: '#all-admin', color: 'good', message: "✅ Build ${env.BUILD_NUMBER} Passed!", tokenCredentialId: 'SLACK_WEBHOOK_URL')
        }
        failure {
            slackSend(channel: '#all-admin', color: 'danger', message: "❌ Build ${env.BUILD_NUMBER} Failed", tokenCredentialId: 'SLACK_WEBHOOK_URL')
        }
    }
}
