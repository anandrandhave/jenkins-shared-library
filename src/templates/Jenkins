pipeline {
    agent any

    tools {
        maven 'Maven3'
        jdk 'JDK'
    }

    environment {
        JOB_NAME = "OT-Microservices-Employee-Service"
        ENV = "dev"
    }

    stages {

        // ✅ Checkout
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        // ✅ Build
        stage('Build') {
            steps {
                sh 'mvn clean compile'
            }
        }

        // ✅ Parallel Testing
        stage('Parallel Tests') {
            parallel {

                stage('Unit Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=*UnitTest test'
                        }
                    }
                }

                stage('Integration Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=*IntegrationTest test'
                        }
                    }
                }

                stage('E2E Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=*E2ETest test'
                        }
                    }
                }
            }
        }

        // ✅ Aggregate Reports
        stage('Aggregate Reports') {
            steps {
                sh 'mvn verify'
            }
        }

        // ✅ Generate Maven Site (HTML reports)
        stage('Generate Site') {
            steps {
                sh 'mvn site'
            }
        }

        // ✅ Debug Site Files (VERY IMPORTANT)
        stage('Debug Site Files') {
            steps {
                sh '''
                echo "===== SITE FILES ====="
                ls -l target/site/
                '''
            }
        }

        // ✅ FINAL FIXED PDF GENERATION
        stage('Generate & Archive PDF') {
            steps {
                sh '''
                echo "===== GENERATING COMBINED HTML ====="

                cat > target/site/full-report.html <<EOF
<html>
<head>
    <title>Employee Service Report</title>
    <style>
        body { font-family: Arial; padding: 20px; }
        h1 { color: #2c3e50; }
        h2 { color: #c0392b; border-bottom: 2px solid #ccc; }
        iframe { width: 100%; height: 800px; border: none; }
    </style>
</head>
<body>

<h1>Employee Service - CI/CD Report</h1>

<h2>Summary</h2>
<iframe src="summary.html"></iframe>

<h2>Test Report</h2>
<iframe src="surefire-report.html"></iframe>

<h2>Coverage Report</h2>
<iframe src="jacoco/index.html"></iframe>

</body>
</html>
EOF

                echo "===== MOVE INTO SITE DIRECTORY ====="
                cd target/site

                echo "===== GENERATING PDF ====="

                wkhtmltopdf \
                --enable-local-file-access \
                full-report.html \
                report.pdf

                echo "===== VERIFY PDF ====="
                ls -l report.pdf
                '''

                script {
                    if (fileExists('target/site/report.pdf')) {
                        echo "✅ PDF FOUND - Archiving..."
                        archiveArtifacts artifacts: 'target/site/report.pdf', fingerprint: true
                    } else {
                        error "❌ PDF not generated!"
                    }
                }
            }
        }
    }

    // ✅ POST ACTIONS
    post {

        // Always publish test results
        always {
            junit '**/target/surefire-reports/*.xml'
        }

        // ✅ SUCCESS SLACK
        success {
            script {
                slackSend(
                    channel: '#all-admin',
                    color: 'good',
                    message: """
✅ *Build SUCCESS*

*Job:* ${env.JOB_NAME}  
*Environment:* ${env.ENV}  

*Stages:*  
✔ Build  
✔ Unit Tests  
✔ Integration Tests  
✔ E2E Tests  
✔ Reports Generated  
✔ PDF Generated  

*Build URL:* ${env.BUILD_URL}  
*Console:* ${env.BUILD_URL}console  
"""
                )
            }
        }

        // ❌ FAILURE SLACK
        failure {
            script {
                slackSend(
                    channel: '#all-admin',
                    color: 'danger',
                    message: """
❌ *Build FAILED*

*Job:* ${env.JOB_NAME}  
*Environment:* ${env.ENV}  

⚠ One or more stages failed  

*Build URL:* ${env.BUILD_URL}  
*Console:* ${env.BUILD_URL}console  
"""
                )
            }
        }
    }
}
