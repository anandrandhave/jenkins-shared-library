pipeline {
    agent any

    tools {
        maven 'Maven'
        jdk 'JDK21'
    }

    environment {
        SONARQUBE_SERVER = 'SonarQube'
    }

    stages {

        stage('Checkout') {
            steps {
                git 'https://github.com/anandrandhave/jenkins-shared-library.git'
            }
        }

        stage('Build & Tests (Parallel)') {
            parallel {

                stage('Unit Tests') {
                    steps {
                        sh 'mvn clean test'
                    }
                    post {
                        always {
                            junit 'target/surefire-reports/*.xml'
                        }
                    }
                }

                stage('Integration Tests') {
                    steps {
                        sh 'mvn verify -DskipUnitTests=true'
                    }
                }

                stage('E2E Tests') {
                    steps {
                        echo "Running E2E Tests..."
                        sh 'echo E2E Passed'
                    }
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv("${SONARQUBE_SERVER}") {
                    withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                        sh '''
                        mvn sonar:sonar \
                        -Dsonar.projectKey=OT-Microservices-Employee-Service \
                        -Dsonar.host.url=http://192.168.1.7:9000 \
                        -Dsonar.login=$SONAR_TOKEN
                        '''
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Generate Site') {
            steps {
                sh 'mvn site'
            }
        }

        stage('Generate & Archive PDF') {
            steps {
                sh '''
                echo "===== GENERATING HTML REPORT ====="

                mkdir -p target/site

                cat <<EOF > target/site/report.html
                <html>
                <body>
                <h1>Build Report</h1>
                <h2>Project: OT-Microservices</h2>
                <p>Status: SUCCESS</p>
                <p>Generated by Jenkins</p>
                </body>
                </html>
                EOF

                echo "===== GENERATING PDF ====="

                wkhtmltopdf \
                --enable-local-file-access \
                --disable-smart-shrinking \
                --no-stop-slow-scripts \
                --load-error-handling ignore \
                target/site/report.html target/site/report.pdf || true

                echo "===== VERIFY PDF ====="
                ls -l target/site

                # Fail if PDF missing
                if [ ! -f target/site/report.pdf ]; then
                  echo "PDF not generated!"
                  exit 1
                fi
                '''

                archiveArtifacts artifacts: 'target/site/report.pdf', fingerprint: true
            }
        }
    }

    post {

        success {
            script {
                def summary = """
:white_check_mark: Unit Tests Passed
:white_check_mark: Integration Tests Passed
:white_check_mark: E2E Tests Passed
:heavy_check_mark: Reports Generated

📄 PDF: ${env.BUILD_URL}artifact/target/site/report.pdf
"""

                echo summary

                slackSend(
                    channel: '#all-admin',
                    color: 'good',
                    message: "✅ SUCCESS: ${env.JOB_NAME} #${env.BUILD_NUMBER}\n${summary}"
                )
            }
        }

        failure {
            slackSend(
                channel: '#all-admin',
                color: 'danger',
                message: "❌ FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER}\nCheck logs: ${env.BUILD_URL}"
            )
        }
    }
}
