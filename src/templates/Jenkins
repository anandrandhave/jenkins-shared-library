pipeline {
    agent any

    tools {
        maven 'Maven3'
        jdk 'JDK'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean compile'
            }
        }

        // ✅ Parallel Execution
        stage('Parallel Tests') {
            parallel {

                stage('Unit Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=UnitTest test'
                        }
                    }
                }

                stage('Integration Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=IntegrationTest test'
                        }
                    }
                }

                stage('E2E Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn -Dtest=E2ETest test'
                        }
                    }
                }
            }
        }
    }

    // ✅ FIXED SLACK NOTIFICATIONS
    post {

        success {
            slackSend(
                channel: '#all-admin',
                message: """
✅ *Build ${env.BUILD_NUMBER} SUCCESS*

📦 Job: ${env.JOB_NAME}
🌿 Branch: ${env.BRANCH_NAME ?: 'N/A'}
🌍 Environment: dev

🧪 Stages:
✔ Build
✔ Unit Tests
✔ Integration Tests
✔ E2E Tests

🔗 Build URL: ${env.BUILD_URL}
📄 Console: ${env.BUILD_URL}console
"""
            )
        }

        failure {
            slackSend(
                channel: '#all-admin',
                message: """
❌ *Build ${env.BUILD_NUMBER} FAILED*

📦 Job: ${env.JOB_NAME}
🌿 Branch: ${env.BRANCH_NAME ?: 'N/A'}
🌍 Environment: dev

🧪 Failed Stages:
⚠ Check Jenkins Stage View for exact failure

🔗 Build URL: ${env.BUILD_URL}
📄 Console: ${env.BUILD_URL}console
"""
            )
        }

        unstable {
            slackSend(
                channel: '#all-admin',
                message: """
⚠ *Build ${env.BUILD_NUMBER} UNSTABLE*

📦 Job: ${env.JOB_NAME}
🌿 Branch: ${env.BRANCH_NAME ?: 'N/A'}
🌍 Environment: dev

🧪 Some tests failed (but pipeline continued)

🔗 Build URL: ${env.BUILD_URL}
📄 Console: ${env.BUILD_URL}console
"""
            )
        }
    }
}
