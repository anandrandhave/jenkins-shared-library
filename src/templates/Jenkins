pipeline {
    agent any

    tools {
        maven 'Maven'
        jdk 'JDK21'
    }

    environment {
        SONARQUBE = 'SonarQube'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build & Unit Tests') {
            steps {
                sh 'mvn clean test'
            }
            post {
                always {
                    junit 'target/surefire-reports/*.xml'
                }
            }
        }

        stage('Integration Tests') {
            steps {
                sh 'mvn verify -DskipUnitTests=true'
            }
        }

        stage('E2E Tests') {
            steps {
                echo "Running E2E Tests..."
                sh 'echo E2E Passed'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv("${SONARQUBE}") {
                    withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                        sh '''
                        mvn sonar:sonar \
                        -Dsonar.projectKey=OT-Microservices-Employee-Service \
                        -Dsonar.host.url=http://192.168.1.7:9000 \
                        -Dsonar.login=$SONAR_TOKEN
                        '''
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Generate Site') {
            steps {
                sh 'mvn site'
            }
        }

        stage('Generate & Archive PDF') {
            steps {
                sh '''
                echo "===== START PDF GENERATION ====="

                mkdir -p target/site

                echo "Creating HTML report..."

cat <<EOF > target/site/full-report.html
<html>
<head>
    <title>CI/CD Report</title>
</head>
<body>
    <h1 style="color:blue;">CI/CD Pipeline Report</h1>
    <h2>Summary</h2>
EOF

                # Append reports safely
                if [ -f target/site/index.html ]; then
                    cat target/site/index.html >> target/site/full-report.html
                fi

                if [ -f target/site/surefire-report.html ]; then
                    cat target/site/surefire-report.html >> target/site/full-report.html
                fi

                echo "</body></html>" >> target/site/full-report.html

                echo "===== GENERATING PDF ====="

                wkhtmltopdf target/site/full-report.html target/site/report.pdf

                echo "===== VERIFY FILE ====="
                ls -l target/site
                '''

                archiveArtifacts artifacts: 'target/site/report.pdf', fingerprint: true
            }
        }
    }

    post {
        always {
            script {

                def status = currentBuild.currentResult
                def icon = status == 'SUCCESS' ? ':heavy_check_mark:' : ':x:'

                def pdfLink = "${env.BUILD_URL}artifact/target/site/report.pdf"

                slackSend(
                    channel: '#all-admin',
                    color: status == 'SUCCESS' ? 'good' : 'danger',
                    message: """
*Pipeline Summary:*
${icon} Unit Tests
${icon} Integration Tests
${icon} E2E Tests
:heavy_check_mark: Reports Generated

*Build:* #${env.BUILD_NUMBER}
*Status:* ${status}
*Job:* ${env.JOB_NAME}

📄 *PDF Report:* ${pdfLink}
🔗 *Build URL:* ${env.BUILD_URL}
"""
                )
            }
        }
    }
}
