@Library('my-shared-library') _

pipeline {
    agent any

    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev', 'test', 'prod'], description: 'Select environment.')
    }

    stages {
        stage('Notify Start') {
            steps {
                script {
                    new com.helper.Notification(this).send("Started")
                }
            }
        }

        stage('Testing') {
            parallel {
                stage('Unit Tests') {
                    steps {
                        // catchError ensures the pipeline continues to reporting even if tests fail
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh 'mvn test -Dtest=Unit* -DfailIfNoTests=false'
                        }
                    }
                }
                stage('Integration Tests') {
                    steps {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh 'mvn test -Dtest=Integration* -DfailIfNoTests=false'
                        }
                    }
                }
            }
        }

        stage('Generate Reports & Artifacts') {
            steps {
                // Generates standard Maven site and documentation
                sh 'mvn site pdf:pdf'
            }
        }

        stage('Generate Custom PDF Report') {
            steps {
                script {
                    // Executes your python script with Jenkins environment variables
                    sh "python3 generate_report.py --jobName '${JOB_NAME}' --buildNum '${BUILD_NUMBER}' --branch '${env.BRANCH_NAME ?: 'main'}' --env '${params.ENVIRONMENT}'"
                }
            }
        }
        
        stage('Archive & Deploy') {
            steps {
                // Archive both the standard Maven PDF and your custom colored PDF
                archiveArtifacts artifacts: 'target/pdf/*.pdf, *.pdf', fingerprint: true
                
                echo "Deploying to ${params.ENVIRONMENT}..."
                sh "sleep 5"
            }
        }
    }

    post {
        always {
            // Records JUnit test results for the Jenkins UI trends
            junit testResults: '**/target/surefire-reports/*.xml', allowEmptyResults: true
        }
        success {
            script { new com.helper.Notification(this).send("Success") }
        }
        failure {
            script { new com.helper.Notification(this).send("Failure") }
        }
        unstable {
            script { new com.helper.Notification(this).send("Unstable") }
        }
        cleanup {
            // The safest place to clean the workspace: runs after ALL notifications are sent
            cleanWs()
        }
    }
}
