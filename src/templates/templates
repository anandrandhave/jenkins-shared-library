@Library('my-shared-library') _

pipeline {
    agent any
    
    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev', 'test', 'prod'], description: 'Select environment.')
    }

    stages {
        stage('Notify Start') {
            steps {
                script { 
                    new com.helper.Notification(this).send("Started") 
                }
            }
        }

        stage('Testing') {
            parallel {
                stage('Unit Tests') {
                    steps {
                        // Changed buildResult to UNSTABLE so failed tests trigger the correct notification
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh 'mvn test -Dtest=Unit* -DfailIfNoTests=false'
                        }
                    }
                }
                stage('Integration Tests') {
                    steps {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh 'mvn test -Dtest=Integration* -DfailIfNoTests=false'
                        }
                    }
                }
            }
        }

        stage('Generate Reports & Artifacts') {
            steps {
                // Generates the standard Maven documentation and PDF
                sh 'mvn site pdf:pdf'
            }
        }

        stage('Generate Custom PDF Report') {
            steps {
                script {
                    // Generates the specific layout using your python script
                    sh """
                        python3 generate_report.py \
                        --job "${JOB_NAME}" \
                        --build "${BUILD_NUMBER}" \
                        --env "${params.ENVIRONMENT}" \
                        --test_results "target/surefire-reports"
                    """
                }
            }
        }

        stage('Deployment') {
            steps {
                echo "Deploying to ${params.ENVIRONMENT}..."
                sh "sleep 15" 
            }
        }
    }
    
    post {
        always {
            // Publishes test results back to Jenkins
            junit testResults: '**/target/surefire-reports/*.xml', allowEmptyResults: true
            // Archives both the standard Maven PDF and your custom python PDF
            archiveArtifacts artifacts: 'test-report.pdf, target/pdf/*.pdf, target/site/jacoco/**', fingerprint: true
            cleanWs()
        }
        success { script { new com.helper.Notification(this).send("Success") } }
        failure { script { new com.helper.Notification(this).send("Failure") } }
        unstable { script { new com.helper.Notification(this).send("Unstable") } }
    }
}
