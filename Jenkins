pipeline {
    agent any

    tools {
        maven 'Maven'
        jdk 'JDK21'
    }

    environment {
        SONAR_PROJECT_KEY = 'OT-Microservices-Employee-Service'
        SONAR_HOST_URL   = 'http://192.168.1.7:9000'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build & Unit Tests') {
            steps {
                sh 'mvn clean test'
            }
            post {
                always {
                    junit 'target/surefire-reports/*.xml'
                }
            }
        }

        stage('Integration Tests') {
            steps {
                sh 'mvn verify -DskipUnitTests=true'
            }
        }

        stage('E2E Tests') {
            steps {
                echo "Running E2E Tests..."
                sh 'echo "E2E Passed"'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                        sh '''
                        mvn sonar:sonar \
                        -Dsonar.projectKey=$SONAR_PROJECT_KEY \
                        -Dsonar.host.url=$SONAR_HOST_URL \
                        -Dsonar.login=$SONAR_TOKEN
                        '''
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Generate Site') {
            steps {
                sh 'mvn clean verify site'
            }
        }

        stage('Generate & Archive PDF') {
            steps {
                sh '''
                echo "===== START PDF STAGE ====="

                mkdir -p target/site

                echo "===== VERIFY HTML FILE ====="
                ls -l target/site

                if [ ! -f target/site/index.html ]; then
                  echo "ERROR: index.html not found!"
                  exit 1
                fi

                echo "===== GENERATING PDF ====="
                wkhtmltopdf --enable-local-file-access --load-error-handling ignore target/site/index.html target/site/report.pdf || true

                echo "===== VERIFY PDF CREATED ====="
                if [ -f target/site/report.pdf ]; then
                    echo "✅ PDF created successfully"
                    ls -l target/site/report.pdf
                else
                    echo "❌ PDF NOT created"
                    exit 1
                fi
                '''
            }

            post {
                always {
                    archiveArtifacts artifacts: 'target/site/report.pdf', fingerprint: true
                }
            }
        }

        // ===============================
        // 🔥 FIX APPLIED HERE ONLY
        // ===============================

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t my-app:${BUILD_NUMBER} .'
            }
        }

        stage('Deploy to Dev') {
            steps {
                milestone(1)

                sh '''
                docker rm -f dev || true
                docker run -d -p 8081:8080 --name dev my-app:${BUILD_NUMBER}
                '''

                script {
                    retry(3) {
                        sleep 10
                        def res = httpRequest(
                            url: "http://127.0.0.1:8081",
                            validResponseCodes: '100:599'
                        )
                        echo "Dev Health: ${res.status}"
                    }
                }
            }
        }

        stage('Approval for Staging') {
            steps {
                milestone(2)
                input message: "Deploy to Staging?"
            }
        }

        stage('Deploy to Staging') {
            steps {
                sh '''
                docker rm -f staging || true
                docker run -d -p 8082:8080 --name staging my-app:${BUILD_NUMBER}
                '''

                script {
                    retry(3) {
                        sleep 10
                        def res = httpRequest(
                            url: "http://127.0.0.1:8082",
                            validResponseCodes: '100:599'
                        )
                        echo "Staging Health: ${res.status}"
                    }
                }
            }
        }

        stage('Production Blue-Green') {
            steps {
                milestone(3)

                script {
                    def active = sh(
                        script: "docker ps --format '{{.Names}}' | grep blue || true",
                        returnStdout: true
                    ).trim() ? "blue" : "green"

                    def idle = (active == "blue") ? "green" : "blue"
                    def port = (idle == "green") ? "8084" : "8083"

                    echo "Deploying to ${idle}"

                    sh """
                    docker rm -f ${idle} || true
                    docker run -d -p ${port}:8080 --name ${idle} my-app:${BUILD_NUMBER}
                    """

                    retry(3) {
                        sleep 10
                        def res = httpRequest(
                            url: "http://127.0.0.1:${port}",
                            validResponseCodes: '100:599'
                        )
                        echo "Production Health: ${res.status}"
                    }

                    echo "Production switched to ${idle}"
                }
            }
        }
    }

    post {
        always {
            script {

                def buildStatus = currentBuild.currentResult

                def unit  = "✅"
                def integ = "✅"
                def e2e   = "✅"

                if (buildStatus != "SUCCESS") {
                    unit  = "❌"
                    integ = "❌"
                    e2e   = "❌"
                }

                def pdfLink = "${env.BUILD_URL}artifact/target/site/report.pdf"

                echo "📄 PDF LINK: ${pdfLink}"

                slackSend(
                    channel: '#all-admin',
                    color: (buildStatus == 'SUCCESS') ? 'good' : 'danger',
                    message: """
*🚀 Pipeline Report*

*Job:* ${env.JOB_NAME}
*Build:* #${env.BUILD_NUMBER}
*Status:* ${buildStatus}

*Pipeline Summary:*
${unit} Unit Tests
${integ} Integration Tests
${e2e} E2E Tests
:heavy_check_mark: Reports Generated

📄 *PDF Report:* ${pdfLink}
"""
                )
            }
        }
    }
}
